{
  "name": "dataviz-observable-projects",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A shared Observable Framework runtime for portable data visualization projects.",
  "workspaces": [
    "*_src"
  ],
  "scripts": {
    "projects": "node scripts/observable-project.mjs list",
    "dev": "node scripts/observable-project.mjs preview",
    "preview": "node scripts/observable-project.mjs preview",
    "build": "node scripts/observable-project.mjs build",
    "build:all": "node scripts/observable-project.mjs build --all"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@observablehq/framework": "^1.13.4"
  }
}
